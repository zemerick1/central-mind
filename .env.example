# Aruba Central API credentials
CENTRAL_BASE_URL=https://internal.api.central.arubanetworks.com
CENTRAL_CLIENT_ID=your-client-id-here
CENTRAL_CLIENT_SECRET=your-client-secret-here

# CentralMind settings
CENTRALMIND_DEBUG=false

# API access mode: readonly (GET only), readwrite (GET+POST+PUT+PATCH), all (includes DELETE)
CENTRALMIND_API_MODE=readonly

# Rate limiting: max sandbox executions per minute (0 = unlimited)
CENTRALMIND_RATE_LIMIT=30

# Max concurrent Deno sandbox processes
CENTRALMIND_MAX_CONCURRENT=5
