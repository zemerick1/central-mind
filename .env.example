# ==========================================
# CentralMind Configuration Template
# ==========================================

# ------------------------------------------
# General Server Settings
# ------------------------------------------
CENTRALMIND_DEBUG=false

# API access mode: readonly (GET only), readwrite (GET+POST+PUT+PATCH), all (includes DELETE)
CENTRALMIND_API_MODE=readonly

# Rate limiting: max sandbox executions per minute (0 = unlimited)
CENTRALMIND_RATE_LIMIT=30

# Max concurrent Deno sandbox processes
CENTRALMIND_MAX_CONCURRENT=5


# ------------------------------------------
# Aruba Central Integration
# ------------------------------------------
# Find your base URL: https://developer.arubanetworks.com/new-central/docs/getting-started-with-rest-apis
CENTRAL_BASE_URL=https://<your-cluster>.central.arubanetworks.com
CENTRAL_CLIENT_ID=your-client-id-here
CENTRAL_CLIENT_SECRET=your-client-secret-here


# ------------------------------------------
# Aruba ClearPass Integration
# ------------------------------------------
# CLEARPASS_BASE_URL=https://clearpass.example.com/api
# CLEARPASS_CLIENT_ID=your-client-id-here
# CLEARPASS_CLIENT_SECRET=your-client-secret-here
# CLEARPASS_VERIFY_SSL=false # Set to false if using a self-signed certificate


# ------------------------------------------
# Juniper Mist Integration
# ------------------------------------------
MIST_APITOKEN=your-api-token-here
MIST_HOST=api.mist.com

# Mist-specific environment settings
MISTMIND_DEBUG=false
MISTMIND_API_MODE=readonly
MISTMIND_RATE_LIMIT=30
MISTMIND_MAX_CONCURRENT=5


# ------------------------------------------
# Juniper Security Director Cloud (SDC) Integration
# ------------------------------------------
SDC_APITOKEN=your-api-token-here
SDC_HOST=api.sdcloud.juniperclouds.net


# ------------------------------------------
# User Experience Insight (UXI) Integration
# ------------------------------------------
# UXI_CLIENT_ID=your-client-id-here
# UXI_CLIENT_SECRET=your-client-secret-here
# UXI_HOST=api.capenetworks.com
# UXI_VERIFY_SSL=false # Set to false if using a corporate proxy or custom CA

# ------------------------------------------
# AOS-CX Integration
# ------------------------------------------
# AOSCX_USERNAME=admin
# AOSCX_PASSWORD=your-password-here
# AOSCX_VERIFY_SSL=false # Typically false for switch self-signed certs
